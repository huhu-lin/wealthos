# ============================================================
# WealthOS — 環境變數範本
# 複製此檔案為 .env.local，填入真實值（不要 commit .env.local！）
# ============================================================

# ── Supabase（前端用，anon key 可公開）──────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── FinMind API Token（只在 Vercel 後端使用，不要加 VITE_ 前綴）
# 取得方式：https://finmindtrade.com → 個人設定 → API Token
FINMIND_TOKEN=your_finmind_jwt_token_here

# ── Supabase（後端 Vercel API 用）────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Telegram Bot（signal-check 推播用）──────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── kline-api（Vercel 呼叫 Railway/Render 後端）─────────────
KLINE_API_URL=https://your-kline-api.railway.app

# ── kline-api CORS（Railway 後端設定，逗號分隔）─────────────
# 範例：https://wealthos.vercel.app,https://wealthos-git-main.vercel.app
ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app
